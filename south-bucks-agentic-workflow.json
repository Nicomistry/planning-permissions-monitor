        "promptType": "define",
        "text": "=={{ JSON.stringify($('Loop Over Applications').item.json) }}",
        "options": {
          "systemMessage": "You are a planning application data extractor for a property development intelligence tool.\n\nExtract structured information from the planning application.\n\nReturn ONLY a valid JSON object in this exact format:\n{\n  \"unit_count\": <number or null if unclear>,\n  \"dwelling_type\": \"<house|flat|bungalow|mixed|unknown>\",\n  \"development_scale\": \"<single|small|medium|large|unknown>\",\n  \"applicant_type\": \"<individual|developer|housing_association|council|unknown>\",\n  \"notes\": \"<one key detail about this development>\"\n}\n\nScale guide:\n- single: 1 unit\n- small: 2-5 units\n- medium: 6-20 units\n- large: 21+ units\n\nBase your extraction on the description, applicant_name, and agent_name fields."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [1560, 112],
