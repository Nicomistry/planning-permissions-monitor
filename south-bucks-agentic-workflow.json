    {
      "parameters": {
        "jsCode": "const app = $('Loop Over Applications').item.json;\nconst enrichmentRaw = $('AI: Enrich Application Data').item.json.output || '';\nconst scoreRaw = $input.item.json.output || '';\n\nlet enrichment = {};\nlet score = {};\n\ntry {\n  const m = enrichmentRaw.match(/\\{[\\s\\S]*\\}/);\n  if (m) enrichment = JSON.parse(m[0]);\n} catch(e) { enrichment = {}; }\n\ntry {\n  const m = scoreRaw.match(/\\{[\\s\\S]*\\}/);\n  if (m) score = JSON.parse(m[0]);\n} catch(e) { score = {}; }\n\nreturn [{\n  json: {\n    uid: app.uid,\n    reference: app.uid,\n    address: app.address,\n    postcode: app.postcode,\n    description: app.description,\n    app_type: app.app_type,\n    app_state: app.app_state,\n    start_date: app.start_date,\n    target_decision_date: app.other_fields?.target_decision_date || null,\n    url: app.url,\n    link: app.link,\n    agent_name: app.other_fields?.agent_name || null,\n    agent_address: app.other_fields?.agent_address || null,\n    applicant_name: app.other_fields?.applicant_name || null,\n    applicant_address: app.other_fields?.applicant_address || null,\n    unit_count: enrichment.unit_count ?? null,\n    dwelling_type: enrichment.dwelling_type || null,\n    development_scale: enrichment.development_scale || null,\n    applicant_type: enrichment.applicant_type || null,\n    enrichment_notes: enrichment.notes || null,\n    opportunity_score: score.score ?? null,\n    priority: score.priority || null,\n    score_reasoning: score.reasoning || null,\n    processed_at: new Date().toISOString(),\n    other_fields: JSON.stringify(app.other_fields || {})\n  }\n}];"
      },
