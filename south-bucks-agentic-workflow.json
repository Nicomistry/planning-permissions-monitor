      "name": "Fetch Planning Applications"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst rawData = items[0].json;\nconst records = rawData.records;\n\nconst targetPrefixes = [\n  'HP5', 'HP6', 'HP7', 'HP8', 'HP9',\n  'HP10', 'HP15', 'HP16',\n  'SL0', 'SL1', 'SL2', 'SL3', 'SL7', 'SL8', 'SL9'\n];\n\nconst filtered = records.filter(app => {\n  if (!app.postcode) return false;\n  const prefix = app.postcode.trim().toUpperCase().split(' ')[0];\n  return targetPrefixes.includes(prefix);\n});\n\nreturn filtered.map(app => ({ json: app }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 240],
      "id": "code-0003-0003-0003-000000000003",
      "name": "Filter by Postcode"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [900, 240],
      "id": "loop-0004-0004-0004-000000000004",
      "name": "Loop Over Applications"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=={{ JSON.stringify($input.item.json) }}",
        "options": {
          "systemMessage": "You are a planning application filter for a property development intelligence tool. Your sole job is to identify planning applications where the end result involves the physical construction of a residential dwelling or dwellings.\n\nYou must return ONLY a valid JSON object in this exact format:\n{\"decision\": \"PASS\", \"reason\": \"Brief reason\"}\nor\n{\"decision\": \"FAIL\", \"reason\": \"Brief reason\"}\n\nPASS if the description involves:\n- Building a new house, flat, bungalow, apartment or residential unit\n- Demolishing an existing building and replacing it with a new dwelling\n- Converting a non-residential building into a dwelling (e.g. barn, office, commercial unit)\n- Adding new residential units on top of or alongside existing buildings\n- Permission in principle or outline applications where the outcome is a new dwelling\n\nFAIL everything else including:\n- Extensions to existing houses\n- Loft conversions\n- Outbuildings, garages, garden rooms\n- Tree works\n- Amendments, conditions, certificates of lawfulness\n- Solar panels, utilities, telecoms\n- Anything where no new dwelling is physically being constructed\n\nOne simple test: will a new house or flat exist that didn't exist before? If yes, PASS. If no, FAIL.\n\nBase your decision on the description field only."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [1120, 112],
      "id": "aiclassify-0005-0005-0005-000000000005",
