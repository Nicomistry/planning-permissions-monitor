      "parameters": {
        "promptType": "define",
        "text": "=={{ JSON.stringify({ application: $('Loop Over Applications').item.json, enrichment: $input.item.json.output }) }}",
        "options": {
          "systemMessage": "You are a property development opportunity scorer for a development intelligence tool targeting the South Bucks / Chilterns area.\n\nScore the planning application as a lead opportunity for a property developer or land agent.\n\nReturn ONLY a valid JSON object in this exact format:\n{\n  \"score\": <integer 1-10>,\n  \"priority\": \"<HIGH|MEDIUM|LOW>\",\n  \"reasoning\": \"<one sentence explaining the score>\"\n}\n\nScoring guide:\n- 9-10: HIGH — Large scheme (6+ units), major conversion, or strategic redevelopment site\n- 7-8: HIGH — Medium scheme (3-5 units) or well-located premium single dwelling\n- 5-6: MEDIUM — Standard 1-2 unit development or infill plot\n- 3-4: LOW — Single replacement dwelling, limited upside\n- 1-2: LOW — Minimal commercial opportunity\n\nConsider: unit count, development scale, postcode desirability (HP postcodes premium), applicant type (individual vs professional developer), and description quality."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [1780, 112],
      "id": "aiscore-0010-0010-0010-000000000010",
