    {
      "parameters": {
        "jsCode": "// PLACEHOLDER — Connect Gmail, Slack, or Webhook after this node\n// This fires only for HIGH priority leads (opportunity_score >= 8)\n\nconst app = $input.item.json;\n\nreturn [{\n  json: {\n    notification_type: 'HIGH_PRIORITY_PLANNING_LEAD',\n    subject: `HIGH Priority Lead: ${app.address} (Score: ${app.opportunity_score}/10)`,\n    body: [\n      `New high-priority planning application detected!`,\n      ``,\n      `Address:     ${app.address}`,\n      `Postcode:    ${app.postcode}`,\n      `Description: ${app.description}`,\n      ``,\n      `Units:       ${app.unit_count ?? 'Unknown'}`,\n      `Type:        ${app.dwelling_type ?? 'Unknown'}`,\n      `Scale:       ${app.development_scale ?? 'Unknown'}`,\n      ``,\n      `Score:       ${app.opportunity_score}/10`,\n      `Priority:    ${app.priority}`,\n      `Reason:      ${app.score_reasoning}`,\n      ``,\n      `Applicant:   ${app.applicant_name ?? 'Unknown'}`,\n      `Agent:       ${app.agent_name ?? 'Unknown'}`,\n      ``,\n      `View: ${app.url || app.link || 'N/A'}`\n    ].join('\\n'),\n    data: app\n  }\n}];"
