        "text": "=={{ JSON.stringify($input.all().map(item => item.json)) }}",
        "options": {
          "systemMessage": "You filter planning applications for residential builders in Guildford, UK.\n\nTASK: Process ALL applications and return UIDs of qualified projects.\n\nKEEP - Residential construction:\n- Extensions (rear, side, front, single/double storey)\n- Loft conversions, dormers, hip-to-gable\n- Outbuildings (garages, studios, garden rooms)\n- Porches, conservatories, orangeries\n- New dwellings, barn conversions\n- Garage conversions with structural work\n\nREJECT - Non-construction:\n- Change of use only (no building)\n- Window/door replacements only\n- Landscaping/boundaries only\n- Materials approval only\n- Drainage/infrastructure only\n- Advertising signs\n\nOUTPUT: Return ONLY a JSON array of UIDs. No explanation. No markdown.\nExample: [\"26/P/00062\",\"26/P/00067\",\"26/P/00061\"]"
        }
      },
