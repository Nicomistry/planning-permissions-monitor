{
  "name": "Guildford Planning Applications Filter",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Get ALL input items\nconst allItems = $input.all();\n\n// Get the first item's JSON\nconst firstItem = allItems[0].json;\n\n// Handle array wrapping\nconst dataObj = Array.isArray(firstItem) ? firstItem[0] : firstItem;\n\n// Get records\nconst applications = dataObj.records;\n\n// STAGE 1: Remove obvious junk\nconst potentialLeads = applications.filter(app => {\n  const appType = (app.app_type || '').toLowerCase();\n  const desc = (app.description || '').toLowerCase();\n  \n  // EXCLUDE: Administrative applications\n  if (appType === 'conditions') return false;\n  if (appType === 'trees') return false;\n  if (desc.includes('discharge of condition')) return false;\n  if (desc.includes('non material amendment')) return false;\n  \n  // EXCLUDE: Non-residential\n  if (desc.includes('commercial')) return false;\n  if (desc.includes('industrial')) return false;\n  if (desc.includes('telecommunications')) return false;\n  if (desc.includes('advertising')) return false;\n  if (desc.includes('signage')) return false;\n  \n  return true;\n});\n\n// Return only fields AI needs\nreturn potentialLeads.map(app => ({\n  json: {\n    uid: app.uid,\n    address: app.address,\n    postcode: app.postcode,\n    description: app.description,\n    app_type: app.app_type,\n    app_state: app.app_state,\n    start_date: app.start_date,\n    url: app.url,\n    link: app.link,\n    target_decision_date: app.other_fields?.target_decision_date || null\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2032,
        336
      ],
      "id": "416dd714-e4d1-4897-906a-da358e2eab4b",
      "name": "Code Filter Stage 1"
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// RESTORE FULL DATA CODE NODE\n// ============================================\n// Purpose: Match AI-filtered UIDs back to original full records\n// Input: AI Agent output (array of UIDs in JSON string)\n// Output: Complete planning application records\n\n// STEP 1: Get AI output and parse UIDs\nconst aiOutput = $input.first().json.output;\n\nlet qualifiedUIDs;\ntry {\n  // Clean any markdown formatting if present\n  const cleaned = aiOutput.replace(/```json|```/g, '').trim();\n  \n  // Parse the JSON array of UIDs\n  qualifiedUIDs = JSON.parse(cleaned);\n  \n} catch (e) {\n  // Fallback: Extract UIDs using regex if JSON parsing fails\n  qualifiedUIDs = aiOutput.match(/\"[\\d\\/A-Z]+\"/g)\n    ?.map(uid => uid.replace(/\"/g, '')) || [];\n}\n\n// STEP 2: Get original full data from HTTP Request node\nconst httpData = $('HTTP Request1').first().json;\n\n// Handle potential array wrapping\nconst originalData = Array.isArray(httpData) \n  ? (httpData[0].records || httpData) \n  : (httpData.records || httpData);\n\n// STEP 3: Match UIDs and restore complete records\nconst qualifiedLeads = originalData.filter(app => \n  qualifiedUIDs.includes(app.uid)\n);\n\n// STEP 4: Return full records with all fields\nreturn qualifiedLeads.map(app => ({ \n  json: {\n    // Application identifiers\n    uid: app.uid,\n    reference: app.uid, // Duplicate for clarity\n    \n    // Location details\n    address: app.address,\n    postcode: app.postcode,\n    \n    // Application details\n    description: app.description,\n    app_type: app.app_type,\n    app_state: app.app_state,\n    \n    // Dates\n    start_date: app.start_date,\n    target_decision_date: app.other_fields?.target_decision_date || null,\n    \n    // Links\n    url: app.url,\n    link: app.link,\n    \n    // Additional fields (if present)\n    decision_date: app.decision_date || null,\n    decision: app.decision || null,\n    agent_name: app.agent_name || null,\n    agent_address: app.agent_address || null,\n    applicant_name: app.applicant_name || null,\n    applicant_address: app.applicant_address || null,\n    \n    // Store all other fields\n    other_fields: app.other_fields || null\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
